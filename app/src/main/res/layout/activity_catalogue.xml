<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EAF7F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Catalogue Behealthy"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp" />

        <!-- Produit 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#F0F0F0"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Produit 1 : Raquette de tennis"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Idéale pour le sport en plein air"
                android:layout_marginTop="6dp" />

            <Button
                android:id="@+id/btnProduit1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Acheter"
                android:layout_marginTop="10dp" />
        </LinearLayout>

        <!-- Produit 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#F0F0F0"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Produit 2 : Équipements sportifs"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pour une activité physique régulière"
                android:layout_marginTop="6dp" />

            <Button
                android:id="@+id/btnProduit2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Acheter"
                android:layout_marginTop="10dp" />
        </LinearLayout>

        <!-- Produit 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#F0F0F0"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Produit 3 : Appareils connectés"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Suivi simple de vos activités"
                android:layout_marginTop="6dp" />

            <Button
                android:id="@+id/btnProduit3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Acheter"
                android:layout_marginTop="10dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>